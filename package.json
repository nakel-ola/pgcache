{
  "name": "pgcache",
  "version": "0.0.0",
  "private": true,
  "description": "Redis-like cache client using PostgreSQL UNLOGGED tables",
  "keywords": [
    "cache",
    "postgresql",
    "postgres",
    "redis",
    "caching",
    "unlogged"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/pgcache.git"
  },
  "license": "MIT",
  "author": "",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "test": "pnpm --filter \"./packages/**\" test",
    "test:watch": "pnpm --filter \"./packages/**\" test:watch",
    "lint": "oxlint .",
    "format": "oxlint --fix .",
    "format:check": "oxlint .",
    "typecheck": "pnpm --filter \"./packages/**\" typecheck",
    "clean": "pnpm --filter \"./packages/**\" clean && rm -rf node_modules",
    "dev": "pnpm --filter \"./packages/**\" dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "oxlint": "^0.18.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
