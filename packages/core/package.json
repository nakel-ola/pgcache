{
  "name": "@pgcache/core",
  "version": "0.1.0",
  "description": "PostgreSQL cache for Node.js with a Redis-like API, TTL support, JSONB values, and UNLOGGED tables",
  "keywords": [
    "pgcache",
    "postgresql-cache",
    "postgres-cache",
    "postgresql",
    "postgres",
    "redis-alternative",
    "redis-like",
    "node-cache",
    "ttl",
    "jsonb",
    "unlogged-tables"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakel-ola/pgcache.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/nakel-ola/pgcache/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/nakel-ola/pgcache/issues"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pgcache/types": "workspace:*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
